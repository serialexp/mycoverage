{
  "name": "mycoverage",
  "version": "1.39.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"pnpm --filter @mycoverage/web dev\" \"pnpm --filter @mycoverage/server dev\"",
    "dev:web": "pnpm --filter @mycoverage/web dev",
    "dev:server": "pnpm --filter @mycoverage/server dev",
    "dev:worker": "pnpm --filter @mycoverage/worker dev",
    "build": "pnpm -r --filter ./packages... build && pnpm --filter @mycoverage/web build && pnpm --filter @mycoverage/server build",
    "build:worker": "pnpm --filter @mycoverage/worker build",
    "build:protobuf": "pnpm --filter @mycoverage/core build:protobuf",
    "studio": "pnpm --filter @mycoverage/db studio",
    "migrate:dev": "pnpm --filter @mycoverage/db migrate:dev",
    "migrate:deploy": "pnpm --filter @mycoverage/db migrate:deploy",
    "db:generate": "pnpm --filter @mycoverage/db generate",
    "test:tsc": "pnpm -r test:tsc",
    "check": "biome check apps packages",
    "check:fix": "biome check --write --unsafe apps packages",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "{apps,packages}/**/*.{js,ts,tsx}": [
      "biome check",
      "biome format"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@vitest/coverage-istanbul": "^4.1.9",
    "concurrently": "^10.0.3",
    "dotenv-cli": "11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "ts-proto": "^2.11.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
