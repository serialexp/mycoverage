{
  "name": "@mycoverage/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./index.ts",
    "./dbtypes": "./dbtypes.ts",
    "./seeds": "./seeds.ts"
  },
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "test:tsc": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "mariadb": "^3.5.3"
  },
  "devDependencies": {
    "dotenv-cli": "11.0.0",
    "prisma": "^7.8.0"
  }
}
