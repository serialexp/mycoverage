{
  "name": "@mycoverage/core",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build:protobuf": "protoc --plugin=../../node_modules/.bin/protoc-gen-ts_proto --ts_proto_opt=esModuleInterop=true --ts_proto_out=./src/library src/library/proto_coverage.proto",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:tsc": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@mycoverage/db": "workspace:*",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-types": "^7.6.1",
    "@smithy/types": "^4.15.0",
    "ajv": "8.20.0",
    "bullmq": "^5.79.2",
    "long": "5.3.2",
    "protobufjs": "^8.6.5",
    "uuidv7": "1.2.1",
    "xml2js": "^0.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/xml2js": "^0.4.14"
  }
}
